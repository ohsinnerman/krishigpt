# .env.example — copy to .env and fill in values

# REQUIRED — get from https://aistudio.google.com/
GOOGLE_API_KEY=

# OPTIONAL — for WhatsApp voice (get from https://bhashini.gov.in/)
BHASHINI_USER_ID=
BHASHINI_API_KEY=

# OPTIONAL — for WhatsApp integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Infra (optional locally — system degrades gracefully if Redis is absent)
REDIS_URL=redis://localhost:6379/0

# RAG Config
RAG_TOP_K=5
REGION_BOOST_EXACT=0.20
REGION_BOOST_ZONE=0.10
REGION_BOOST_PAN_INDIA=0.05
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=10
MAX_TOKENS_OUTPUT=500

# Model Config
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=data/faiss.index
CHUNKS_PATH=data/chunks.pkl
PINCODE_DB_PATH=data/pincodes.csv

ENVIRONMENT=development
LOG_LEVEL=INFO
